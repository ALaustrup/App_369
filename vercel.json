{
  "version": 2,
  "public": true,
  "buildCommand": "echo \"Static landing deployment\"",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/download/astra-matrix-latest.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"astra-matrix-latest.apk\"" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/download/latest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/download/(.*)", "destination": "/download/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
